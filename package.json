{
  "name": "competehive",
  "version": "1.0.0",
  "private": true,
  "description": "Dynamic price tracking & competitor analysis platform for e-commerce sellers",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @competehive/web run dev",
    "dev:worker": "npm --workspace @competehive/worker run dev",
    "build": "npm run build:web && npm run build:worker",
    "build:web": "npm --workspace @competehive/web run build",
    "build:worker": "npm --workspace @competehive/worker run build",
    "db:generate": "npm --workspace @competehive/database run generate",
    "db:push": "npm --workspace @competehive/database run push",
    "db:migrate": "npm --workspace @competehive/database run migrate",
    "db:studio": "npm --workspace @competehive/database run studio",
    "db:seed": "npm --workspace @competehive/database exec prisma db seed",
    "db:deploy": "npm --workspace @competehive/database run deploy"
  },
  "author": "Alptekin Ayyavuz",
  "license": "UNLICENSED"
}
