# ============================================
# CompeteHive - Environment Variables
# ============================================

# Database (Railway PostgreSQL)
DATABASE_URL="postgresql://postgres:PASSWORD@HOST:PORT/railway"

# Redis (Railway Redis)
REDIS_URL="redis://default:PASSWORD@HOST:PORT"

# Clerk Auth — NEVER commit real keys. Copy this file to .env and fill in.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_your-clerk-publishable-key"
CLERK_SECRET_KEY="sk_test_your-clerk-secret-key"
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Telegram Bot
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_WEBHOOK_SECRET="your-telegram-webhook-secret"

# Email (Resend) — worker sends price alerts
RESEND_API_KEY="re_..."
RESEND_FROM_EMAIL="CompeteHive <onboarding@resend.dev>"

# Whop (Ödeme) — abonelik & faturalama
WHOP_API_KEY="..."
WHOP_WEBHOOK_SECRET="ws_..."
# Whop product ID → plan tier (webhook membership.activated eşlemesi)
WHOP_STARTER_PRODUCT_ID="prod_..."
WHOP_PRO_PRODUCT_ID="prod_..."
WHOP_ENTERPRISE_PRODUCT_ID="prod_..."
# Whop plan ID → checkout (aylık + yıllık). Öneksiz adlar tercih edilir:
# yalnızca sunucuda okunur ve runtime'da çözülür (rebuild gerektirmez).
# NEXT_PUBLIC_* eşdeğerleri build'e gömülür; hem eski dağıtımlar hem de
# fiyatlandırma sayfasının "yıllık plan mevcut mu" kontrolü için ikisini de
# ayarlayın. Yıllık ID'ler ayarlanmazsa UI yıllık seçeneğini otomatik gizler.
WHOP_STARTER_PLAN_ID="plan_..."
WHOP_PRO_PLAN_ID="plan_..."
WHOP_ENTERPRISE_PLAN_ID="plan_..."
WHOP_STARTER_YEARLY_PLAN_ID="plan_..."
WHOP_PRO_YEARLY_PLAN_ID="plan_..."
WHOP_ENTERPRISE_YEARLY_PLAN_ID="plan_..."
NEXT_PUBLIC_WHOP_STARTER_PLAN_ID="plan_..."
NEXT_PUBLIC_WHOP_PRO_PLAN_ID="plan_..."
NEXT_PUBLIC_WHOP_ENTERPRISE_PLAN_ID="plan_..."
NEXT_PUBLIC_WHOP_STARTER_YEARLY_PLAN_ID="plan_..."
NEXT_PUBLIC_WHOP_PRO_YEARLY_PLAN_ID="plan_..."
NEXT_PUBLIC_WHOP_ENTERPRISE_YEARLY_PLAN_ID="plan_..."

# Proxy (Scraping için) — üretimde datacenter IP'leri pazaryerlerince
# bloklandığı için residential proxy şiddetle önerilir
PROXY_HOST=""
PROXY_PORT=""
PROXY_USER=""
PROXY_PASS=""

# Hata takibi (Sentry) — DSN yoksa hata raporlama no-op çalışır
SENTRY_DSN=""

# Reklam/analitik pixel'leri — yalnızca çerez onayı verildikten sonra yüklenir.
# Kampanya başlayınca doldurun; boşsa hiçbir script eklenmez.
NEXT_PUBLIC_META_PIXEL_ID=""
NEXT_PUBLIC_TIKTOK_PIXEL_ID=""

# App
NODE_ENV="development"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="CompeteHive"

# Admin bootstrap (comma-separated allowlists)
ADMIN_EMAILS="owner@company.com, second-admin@company.com"
ADMIN_CLERK_IDS="user_2abc123, user_2def456"
