// CompeteHive Database Schema
// Dynamic Price Tracking & Competitor Analysis Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USERS & AUTH
// ============================================

enum Plan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

model User {
  // Clerk user IDs are string values like "user_xxx" (not UUID).
  // NOTE: existing databases require a migration for users.id/password_hash changes.
  id               String   @id
  email            String   @unique
  name             String?
  plan             Plan     @default(FREE)
  maxProducts      Int      @default(5) @map("max_products")
  telegramChatId   String?  @map("telegram_chat_id")
  webhookUrl       String?  @map("webhook_url")
  stripeCustomerId String?  @map("stripe_customer_id")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  trackedProducts TrackedProduct[]
  alertRules      AlertRule[]
  notifications   Notification[]
  apiKeys         ApiKey[]

  @@map("users")
}

model ApiKey {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  key       String    @unique
  name      String
  isActive  Boolean   @default(true) @map("is_active")
  lastUsed  DateTime? @map("last_used")
  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("api_keys")
}

// ============================================
// PRODUCTS & TRACKING
// ============================================

enum Marketplace {
  TRENDYOL
  HEPSIBURADA
  AMAZON_TR
  N11
  CICEKSEPETI
  PTTAVM
  AKAKCE
  CIMRI
  EPEY
  SHOPIFY
  CUSTOM
}

enum ProductStatus {
  ACTIVE
  PAUSED
  ERROR
  OUT_OF_STOCK
}

model TrackedProduct {
  id             String        @id @default(uuid())
  userId         String        @map("user_id")
  productName    String        @map("product_name")
  marketplace    Marketplace
  productUrl     String        @map("product_url")
  productImage   String?       @map("product_image")
  sellerName     String?       @map("seller_name")
  category       String?
  currentPrice   Decimal?      @db.Decimal(12, 2) @map("current_price")
  currency       String        @default("TRY")
  status         ProductStatus @default(ACTIVE)
  lastScrapedAt  DateTime?     @map("last_scraped_at")
  scrapeInterval Int           @default(60) @map("scrape_interval") // dakika cinsinden
  metadata       Json? // ek marketplace spesifik veriler
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  priceHistory PriceHistory[]
  alertRules   AlertRule[]
  competitors  Competitor[]

  @@index([userId, marketplace])
  @@index([status, lastScrapedAt])
  @@map("tracked_products")
}

model PriceHistory {
  id               BigInt   @id @default(autoincrement())
  trackedProductId String   @map("tracked_product_id")
  price            Decimal  @db.Decimal(12, 2)
  previousPrice    Decimal? @db.Decimal(12, 2) @map("previous_price")
  currency         String   @default("TRY")
  priceChange      Decimal? @db.Decimal(12, 2) @map("price_change")
  priceChangePct   Decimal? @db.Decimal(8, 4) @map("price_change_pct")
  inStock          Boolean  @default(true) @map("in_stock")
  sellerName       String?  @map("seller_name")
  scrapedAt        DateTime @default(now()) @map("scraped_at")

  trackedProduct TrackedProduct @relation(fields: [trackedProductId], references: [id], onDelete: Cascade)

  @@index([trackedProductId, scrapedAt])
  @@index([scrapedAt])
  @@map("price_history")
}

// ============================================
// COMPETITOR TRACKING
// ============================================

model Competitor {
  id               String    @id @default(uuid())
  trackedProductId String    @map("tracked_product_id")
  competitorUrl    String    @map("competitor_url")
  competitorName   String?   @map("competitor_name")
  marketplace      Marketplace
  currentPrice     Decimal?  @db.Decimal(12, 2) @map("current_price")
  lastScrapedAt    DateTime? @map("last_scraped_at")
  createdAt        DateTime  @default(now()) @map("created_at")

  trackedProduct   TrackedProduct    @relation(fields: [trackedProductId], references: [id], onDelete: Cascade)
  competitorPrices CompetitorPrice[]

  @@map("competitors")
}

model CompetitorPrice {
  id           BigInt   @id @default(autoincrement())
  competitorId String   @map("competitor_id")
  price        Decimal  @db.Decimal(12, 2)
  currency     String   @default("TRY")
  inStock      Boolean  @default(true) @map("in_stock")
  scrapedAt    DateTime @default(now()) @map("scraped_at")

  competitor Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)

  @@index([competitorId, scrapedAt])
  @@map("competitor_prices")
}

// ============================================
// ALERTS & NOTIFICATIONS
// ============================================

enum RuleType {
  PRICE_DROP // fiyat düştüğünde
  PRICE_INCREASE // fiyat arttığında
  PRICE_THRESHOLD // belirli fiyatın altına/üstüne geçtiğinde
  PERCENTAGE_CHANGE // yüzde değişim
  COMPETITOR_CHEAPER // rakip daha ucuz olduğunda
  OUT_OF_STOCK // stoktan çıktığında
  BACK_IN_STOCK // stoğa girdiğinde
}

enum NotifyChannel {
  EMAIL
  TELEGRAM
  WEBHOOK
}

model AlertRule {
  id               String          @id @default(uuid())
  userId           String          @map("user_id")
  trackedProductId String?         @map("tracked_product_id")
  ruleType         RuleType        @map("rule_type")
  thresholdValue   Decimal?        @db.Decimal(12, 2) @map("threshold_value")
  direction        String? // "above" veya "below" (threshold için)
  notifyVia        NotifyChannel[] @map("notify_via")
  isActive         Boolean         @default(true) @map("is_active")
  lastTriggered    DateTime?       @map("last_triggered")
  cooldownMinutes  Int             @default(60) @map("cooldown_minutes")
  createdAt        DateTime        @default(now()) @map("created_at")

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  trackedProduct TrackedProduct? @relation(fields: [trackedProductId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@map("alert_rules")
}

model Notification {
  id          String       @id @default(uuid())
  userId      String       @map("user_id")
  alertRuleId String?      @map("alert_rule_id")
  channel     NotifyChannel
  title       String
  message     String
  metadata    Json?
  isRead      Boolean      @default(false) @map("is_read")
  sentAt      DateTime     @default(now()) @map("sent_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  alertRule AlertRule? @relation(fields: [alertRuleId], references: [id], onDelete: SetNull)

  @@index([userId, isRead])
  @@map("notifications")
}

// ============================================
// SCRAPING & SYSTEM
// ============================================

enum JobStatus {
  PENDING
  RUNNING
  COMPLETED
  FAILED
}

model ScrapeJob {
  id               String     @id @default(uuid())
  trackedProductId String     @map("tracked_product_id")
  marketplace      Marketplace
  status           JobStatus  @default(PENDING)
  attempts         Int        @default(0)
  result           Json?
  error            String?
  startedAt        DateTime?  @map("started_at")
  completedAt      DateTime?  @map("completed_at")
  createdAt        DateTime   @default(now()) @map("created_at")

  @@index([status, createdAt])
  @@map("scrape_jobs")
}

model SystemLog {
  id        BigInt   @id @default(autoincrement())
  level     String // info, warn, error
  service   String // web, worker, scraper
  message   String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  @@index([level, createdAt])
  @@map("system_logs")
}
